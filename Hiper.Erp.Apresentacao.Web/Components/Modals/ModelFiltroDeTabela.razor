@using Hiper.Erp.Aplicacao.Dtos.ObjetosDeValor.Tabelas
@using Hiper.Erp.Dominio.Enumeradores
@using Hiper.Erp.Aplicacao.Dtos.ObjetosDeValor.Filtros
@using Hiper.Erp.Apresentacao.Web.Components.Inputs

@if (Coluna != null)
{
    <div class="modal fade show d-block rounded-0 shadow-sm" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Filtros - @Coluna.NomeColuna</h5>
                    <button type="button" class="btn btn-sm btn-default" @onclick="Fechar">
                        <i class="fas fa-times-circle"></i>
                    </button>
                </div>

                <div class="modal-body">

                    @foreach (var filtro in Filtros)
                    {
                        <div class="row mb-2 align-items-center">

                            <InputSelectSinglePadrao FormGroupClass="col-12 col-md-5"
                                                     Label="Tipo Filtro"
                                                     @bind-Value="filtro.TipoFiltro">

                                @foreach (var tipo in EnumTipoFiltroQueryExtensions.Listar())
                                {
                                    <option value="@tipo.Valor">@tipo.Descricao</option>
                                }

                            </InputSelectSinglePadrao>

                            <InputButtonPadrao FormGroupClass="col-12 col-md-7"
                                               Label="Valor do filtro"
                                               @bind-Value="filtro.Valor"
                                               ButtonTitle="Remover filtro"
                                               OnButtonClick="() => RemoverFiltro(filtro)">

                                <Icon>
                                    <i class="fas fa-trash-alt"></i>
                                </Icon>

                            </InputButtonPadrao>

                        </div>
                    }

                    <button class="btn btn-sm btn-default" @onclick="AdicionarFiltro">
                        <i class="fas fa-plus"></i>
                        Adicionar filtro
                    </button>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-sm btn-default" @onclick="Resetar">
                        <i class="fas fa-eraser me-1"></i>
                        Limpar
                    </button>

                    <button class="btn btn-sm btn-default" @onclick="Aplicar">
                        <i class="fas fa-check me-1"></i>
                        Aplicar Filtros
                    </button>

                </div>
            </div>
        </div>
    </div>
}



@code {
    [Parameter] public TabelaColuna? Coluna { get; set; }
    [Parameter] public EventCallback<DtoFiltroCampo> OnAplicar { get; set; }
    [Parameter] public EventCallback OnFechar { get; set; }
    [Parameter] public List<FiltroCampo> FiltrosExistentes { get; set; } = new();

    private List<FiltroCampo> Filtros = new();

    protected override void OnParametersSet()
    {
        if (Coluna != null)
        {
            // Clonar os filtros existentes para edição local no modal
            Filtros = FiltrosExistentes.Select(f => new FiltroCampo
            {
                TipoFiltro = f.TipoFiltro,
                Valor = f.Valor
            }).ToList();

            if (Filtros.Count == 0)
            {
                AdicionarFiltro();
            }
        }
    }

    void AdicionarFiltro() => Filtros.Add(new FiltroCampo { TipoFiltro = EnumTipoFiltroQuery.Contem });

    void RemoverFiltro(FiltroCampo f) => Filtros.Remove(f);

    void Resetar() => Filtros.Clear();

    async Task Aplicar()
    {
        var campo = new DtoFiltroCampo
        {
            Nome = Coluna!.NomePropriedade,
            Valores = Filtros
                .Where(f => !string.IsNullOrWhiteSpace(f.Valor))
                .Select(f => new DtoFiltroCampoValor
                {
                    Valor = f.Valor!,
                    TipoFiltro = f.TipoFiltro
                }).ToList()
        };

        // Atualizar a lista de filtros originais para persistência visual no modal
        FiltrosExistentes.Clear();
        FiltrosExistentes.AddRange(Filtros.Where(f => !string.IsNullOrWhiteSpace(f.Valor)));

        await OnAplicar.InvokeAsync(campo);
        await Fechar();
    }

    async Task Fechar()
    {
        await OnFechar.InvokeAsync();
    }
}
