<style>

    .indicador-card-custom {
        transition: transform 0.3s ease;
        cursor: pointer;
    }

        .indicador-card-custom:hover {
            transform: translateY(-5px) !important;
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }

    .icon-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
        flex-shrink: 0;
    }
</style>

<div class="card border-0 shadow-sm rounded-4 h-100 indicador-card-custom">

    <div class="card-body d-flex align-items-center justify-content-between p-3">
        <div class="me-3">
            <div class="text-body-secondary small mb-1 d-flex align-items-center">
                @Titulo
                <i class="fa-solid fa-chevron-right ms-1" style="font-size: 0.75rem;"></i>
            </div>
            <h4 class="mb-0 fw-bold text-body-emphasis">@Valor</h4>
        </div>

        <div class="icon-circle" style="background-color: @CorFundo;">
            <i class="@IconeCssClass"></i>
        </div>
    </div>

</div>

@code {
    [Parameter] public string Titulo { get; set; } = "Título";
    [Parameter] public string Valor { get; set; } = "R$ 0,00";
    [Parameter] public string IconeCssClass { get; set; } = "fa-solid fa-chart-line";
    [Parameter] public string CorFundo { get; set; } = "#0d6efd";
}