<div class="form-group @FormGroupClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="control-label text-muted small mb-1">@Label</label>
    }

    <div class="input-group">
        <input class="form-control @InputClass"
               placeholder="@Placeholder"
               disabled="@Disabled"
               value="@Value"
               @oninput="OnInput" />

        <button type="button"
                class="btn btn-sm btn-default @ButtonClass"
                title="@ButtonTitle"
                @onclick="OnClick">
            @if (Icon != null)
            {
                @Icon
            }
        </button>
    </div>
</div>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    [Parameter] public EventCallback OnButtonClick { get; set; }

    [Parameter] public string? ButtonTitle { get; set; }
    [Parameter] public bool Disabled { get; set; }

    [Parameter] public string? FormGroupClass { get; set; }
    [Parameter] public string? InputClass { get; set; }
    [Parameter] public string? ButtonClass { get; set; }

    [Parameter] public RenderFragment? Icon { get; set; }

    private async Task OnInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }

    private async Task OnClick()
    {
        await OnButtonClick.InvokeAsync();
    }
}