@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

@if (_isLoading)
{
    <div style="display: flex; justify-content: center; align-items: center; height: 100vh; background-color: #f5f5f5;">
        <div style="text-align: center;">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
            <p style="margin-top: 20px; color: #666;">Carregando aplicação...</p>
        </div>
    </div>
}
else
{
    @ChildContent
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // Aguarda o carregamento do estado de autenticação
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        
        // Se não está autenticado e não está na página de login, redireciona
        if (!authState.User.Identity?.IsAuthenticated ?? true)
        {
            var currentUri = new Uri(Navigation.Uri);
            if (!currentUri.AbsolutePath.Contains("/Auth/Login"))
            {
                Navigation.NavigateTo("/Auth/Login", forceLoad: false);
            }
        }

        _isLoading = false;
    }
}
