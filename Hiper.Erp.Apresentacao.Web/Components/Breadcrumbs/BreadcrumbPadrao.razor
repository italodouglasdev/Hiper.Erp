<nav aria-label="breadcrumb" class="@Class" @attributes="AdditionalAttributes">
  <ol class="breadcrumb">
    @foreach (var item in Items)
    {
        <li class="breadcrumb-item @(item.Active ? "active" : "")" aria-current="@(item.Active ? "page" : null)">
            @if (item.Active || string.IsNullOrEmpty(item.Href))
            {
                @item.Text
            }
            else
            {
                <a href="@item.Href">@item.Text</a>
            }
        </li>
    }
  </ol>
</nav>

@code {
    [Parameter] public List<BreadcrumbItem> Items { get; set; } = new();
    [Parameter] public string Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object> AdditionalAttributes { get; set; }

    public class BreadcrumbItem
    {
        public string Text { get; set; }
        public string Href { get; set; }
        public bool Active { get; set; }
    }
}
