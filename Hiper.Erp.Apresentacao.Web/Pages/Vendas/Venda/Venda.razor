@page "/Vendas/Venda"

@using Hiper.Erp.Aplicacao.Dtos.Vendas
@using Hiper.Erp.Aplicacao.Dtos.Agentes
@using Hiper.Erp.Aplicacao.Dtos.FormasPagamentos
@using Hiper.Erp.Aplicacao.Dtos.Produtos
@using Hiper.Erp.Aplicacao.Dtos.Filtros
@using Hiper.Erp.Aplicacao.Interfaces.Servicos
@using Hiper.Erp.Aplicacao.Interfaces.Servicos.Vendas
@using Hiper.Erp.Aplicacao.Interfaces.Servicos.Agentes
@using Hiper.Erp.Aplicacao.Interfaces.Servicos.FormasPagamentos
@using Hiper.Erp.Aplicacao.Interfaces.Servicos.Produtos
@using Hiper.Erp.Apresentacao.Web.Components.Accordions
@using Hiper.Erp.Apresentacao.Web.Components.Buttons
@using Hiper.Erp.Apresentacao.Web.Components.Cards
@using Hiper.Erp.Apresentacao.Web.Components.Containers
@using Hiper.Erp.Apresentacao.Web.Components.Table
@using Hiper.Erp.Apresentacao.Web.Components.Modals
@inject IServicoVendas ApiServicoVendas
@inject IServicoVendasItens ApiServicoVendasItens
@inject IServicoAgentes ApiServicoAgentes
@inject IServicoFormasPagamentos ApiServicoFormasPagamentos
@inject IServicoProdutos ApiServicoProdutos
@inject IJSRuntime JS

<ContainerPadrao Breakpoint="xxl">
    <RowPadrao>
        <ColPadrao>
            <CardPadrao>

                <CardHeaderPadrao Class="p-3">

                    <AccordionPadrao Class="mb-0">
                        <AccordionItem Title="@Titulo" Icon="nav-icon fas fa-shopping-cart"> </AccordionItem>
                    </AccordionPadrao>

                </CardHeaderPadrao>

                <CardBodyPadrao Class="p-0">

                    <TablePadrao TItem="DtoVenda"
                                 Itens="@listaVendas"
                                 ItensPorPagina="10"
                                 OnPaginaAlterada="PaginaAlterada"
                                 OnFiltrar="CarregarLista"
                                 OnAdicionar="Novo"
                                 OnRowClick="Editar">

                        <ColunaAcoes Context="item">
                            <VendaAcoes Venda="item"
                                        OnEditar="Editar" />
                        </ColunaAcoes>

                    </TablePadrao>
                </CardBodyPadrao>
            </CardPadrao>
        </ColPadrao>
    </RowPadrao>
</ContainerPadrao>

<ModalPadrao Title="@(venda.Codigo == 0 ? "Nova Venda" : "Editar Venda")"
             Visible="@exibirModal"
             CloseOnBackdrop="false"
             Size="xl"
             Centered="true">
    <ChildContent>
        <VendaFormulario Venda="venda" 
                         Clientes="listaClientes" 
                         FormasPagamento="listaFormasPagamento" 
                         Produtos="listaProdutos"
                         Itens="listaItensVenda"
                         OnAdicionarItem="AdicionarItem"
                         OnEditarItem="EditarItem"
                         OnExcluirItem="ExcluirItem" />
    </ChildContent>
    <FooterContent>
        @if (venda.Codigo > 0)
        {
            <ButtonPadrao Class="btn-secondary" OnClick="Excluir">
                <i class="fas fa-trash me-2"></i> Excluir
            </ButtonPadrao>
        }

        <ButtonPadrao Class="btn-secondary" OnClick="FecharModal">
            <i class="fas fa-times me-2"></i> Cancelar
        </ButtonPadrao>
        <ButtonPadrao Class="btn-primary" OnClick="Salvar">
            <i class="fas fa-save me-2"></i> Salvar Venda
        </ButtonPadrao>
    </FooterContent>
</ModalPadrao>


@code {

    protected override async Task OnInitializedAsync()
    {
        await CarregarDadosIniciais();
        await CarregarLista();
    }

    #region Propriedades

    private DtoVenda venda = new();
    private List<DtoVenda> listaVendas = new();
    private List<DtoVendaItem> listaItensVenda = new();
    
    private List<DtoAgente> listaClientes = new();
    private List<DtoFormaPagamento> listaFormasPagamento = new();
    private List<DtoProduto> listaProdutos = new();

    private int paginaAtual = 1;
    private string Titulo = "Consulta de Vendas";
    private bool exibirModal = false;
    private DtoFiltro filtroAtual = new();

    #endregion

    private async Task CarregarDadosIniciais()
    {
        var resClientes = await ApiServicoAgentes.ObtenhaLista();
        if (resClientes.Sucesso) listaClientes = resClientes.Dados ?? new();

        var resFormas = await ApiServicoFormasPagamentos.ObtenhaLista();
        if (resFormas.Sucesso) listaFormasPagamento = resFormas.Dados ?? new();

        var resProdutos = await ApiServicoProdutos.ObtenhaLista();
        if (resProdutos.Sucesso) listaProdutos = resProdutos.Dados ?? new();
    }

    #region Paginacao

    private async Task CarregarLista(DtoFiltro filtro = null)
    {
        filtroAtual = filtro;
        paginaAtual = 1;

        var response = new Aplicacao.Dtos.Wrappers.ResultadoOperacao<List<DtoVenda>>();

        if (filtro?.Campos?.Count > 0)
        {
            response = await ApiServicoVendas.ObtenhaListaComFiltros(filtro);
        }
        else
        {
            response = await ApiServicoVendas.ObtenhaLista();
        }

        if (response.Sucesso)
        {
            listaVendas = response.Dados ?? new();
        }
    }

    private void PaginaAlterada(int novaPagina)
    {
        paginaAtual = novaPagina;
    }

    #endregion

    #region CRUD Venda

    private void Novo()
    {
        venda = new DtoVenda { DataHora = DateTime.Now };
        listaItensVenda = new List<DtoVendaItem>();
        exibirModal = true;
    }

    private async Task Editar(DtoVenda item)
    {
        this.venda = new DtoVenda
        {
            Codigo = item.Codigo,
            CodigoCliente = item.CodigoCliente,
            NomeCliente = item.NomeCliente,
            CodigoFormaPagamento = item.CodigoFormaPagamento,
            FormaPagamento = item.FormaPagamento,
            DataHora = item.DataHora,
            Descricao = item.Descricao
        };

        // Carregar itens da venda
        var filtro = new DtoFiltro();
        filtro.Campos.Add(new DtoFiltroCampo { Nome = "CodigoVenda",/*  Valor = item.Codigo.ToString() */ });
        var resItens = await ApiServicoVendasItens.ObtenhaListaComFiltros(filtro);
        if (resItens.Sucesso)
        {
            listaItensVenda = resItens.Dados ?? new();
        }
        else
        {
            listaItensVenda = new();
        }

        exibirModal = true;
    }

    private async Task Salvar()
    {
        var novo = venda.Codigo == 0;

        var confirmado = await JS.InvokeAsync<bool>("MessageBoxConfirmacao",
                                    novo == true ? $"Deseja realmente cadastrar esta venda?" :
                                                   $"Deseja realmente atualizar esta venda?");

        if (confirmado)
        {
            var response = novo == true ? await ApiServicoVendas.Cadastrar(venda) : await ApiServicoVendas.Atualizar(venda);

            if (response.Sucesso)
            {
                // Se for nova venda, atualizar o código nos itens antes de salvar (se a API não fizer automático)
                // Nota: Em um ERP real, os itens seriam salvos junto ou após a venda ter um ID.
                // Aqui vamos assumir que precisamos salvar os itens um a um se forem novos.
                
                foreach (var item in listaItensVenda)
                {
                    item.CodigoVenda = response.Dados.Codigo;
                    if (item.Codigo == 0)
                        await ApiServicoVendasItens.Cadastrar(item);
                    else
                        await ApiServicoVendasItens.Atualizar(item);
                }

                await JS.InvokeVoidAsync("MessageBoxResultado", response.Sucesso, response.Mensagem);
                exibirModal = false;
                await CarregarLista();
            }
            else
            {
                await JS.InvokeVoidAsync("MessageBoxResultado", response.Sucesso, response.Mensagem);
            }
        }
    }

    private async Task Excluir()
    {
        var confirmado = await JS.InvokeAsync<bool>("MessageBoxConfirmacao",
                                                   $"Deseja realmente excluir a venda {venda.Codigo}?");

        if (confirmado)
        {
            var response = await ApiServicoVendas.Deletar(venda.Codigo);

            await JS.InvokeVoidAsync("MessageBoxResultado", response.Sucesso, response.Mensagem);

            if (response.Sucesso)
            {
                exibirModal = false;
                await CarregarLista();
            }
        }
    }

    #endregion

    #region Gestão de Itens (Em memória no modal)

    private void AdicionarItem(DtoVendaItem item)
    {
        listaItensVenda.Add(item);
        StateHasChanged();
    }

    private void EditarItem(DtoVendaItem item)
    {
        var index = listaItensVenda.FindIndex(i => (i.Codigo > 0 && i.Codigo == item.Codigo) || (i.Codigo == 0 && i == item));
        if (index != -1)
        {
            listaItensVenda[index] = item;
        }
        StateHasChanged();
    }

    private async Task ExcluirItem(DtoVendaItem item)
    {
        if (item.Codigo > 0)
        {
            var res = await ApiServicoVendasItens.Deletar(item.Codigo);
            if (!res.Sucesso)
            {
                await JS.InvokeVoidAsync("MessageBoxResultado", false, "Erro ao excluir item do banco: " + res.Mensagem);
                return;
            }
        }
        
        listaItensVenda.Remove(item);
        StateHasChanged();
    }

    #endregion

    private void FecharModal()
    {
        exibirModal = false;
    }
}
