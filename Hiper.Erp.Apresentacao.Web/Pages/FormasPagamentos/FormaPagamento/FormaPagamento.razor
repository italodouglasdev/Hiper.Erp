@page "/FormasPagamentos/FormaPagamento"

@using Hiper.Erp.Aplicacao.Dtos.FormasPagamentos
@using Hiper.Erp.Aplicacao.Dtos.Filtros
@using Hiper.Erp.Aplicacao.Interfaces.Servicos
@using Hiper.Erp.Aplicacao.Interfaces.Servicos.FormasPagamentos
@using Hiper.Erp.Apresentacao.Web.Components.Accordions
@using Hiper.Erp.Apresentacao.Web.Components.Buttons
@using Hiper.Erp.Apresentacao.Web.Components.Cards
@using Hiper.Erp.Apresentacao.Web.Components.Containers
@using Hiper.Erp.Apresentacao.Web.Components.Table
@using Hiper.Erp.Apresentacao.Web.Components.Modals
@inject IServicoFormasPagamentos ApiServicoFormasPagamentos
@inject IJSRuntime JS

<ContainerPadrao Breakpoint="xxl">
    <RowPadrao>
        <ColPadrao>
            <CardPadrao>

                <CardHeaderPadrao Class="p-3">

                    <AccordionPadrao Class="mb-0">
                        <AccordionItem Title="@Titulo" Icon="nav-icon fas fa-credit-card"> </AccordionItem>
                    </AccordionPadrao>

                </CardHeaderPadrao>

                <CardBodyPadrao Class="p-0">

                    <TablePadrao TItem="DtoFormaPagamento"
                                 Itens="@listaFormasPagamento"
                                 ItensPorPagina="10"
                                 OnPaginaAlterada="PaginaAlterada"
                                 OnFiltrar="CarregarLista"
                                 OnAdicionar="Novo"
                                 OnRowClick="Editar">

                        <ColunaAcoes Context="item">
                            <FormaPagamentoAcoes FormaPagamento="item"
                                                 OnEditar="Editar" />
                        </ColunaAcoes>

                    </TablePadrao>
                </CardBodyPadrao>
            </CardPadrao>
        </ColPadrao>
    </RowPadrao>
</ContainerPadrao>

<ModalPadrao Title="@(formaPagamento.Codigo == 0 ? "Nova" : "Editar")"
             Visible="@exibirModal"
             CloseOnBackdrop="false"
             Size="xl"
             Centered="true">
    <ChildContent>
        <FormaPagamentoFormulario FormaPagamento="formaPagamento" />
    </ChildContent>
    <FooterContent>
        @if (formaPagamento.Codigo > 0)
        {
            <ButtonPadrao Class="btn-secondary" OnClick="Excluir">
                <i class="fas fa-trash me-2"></i> Excluir
            </ButtonPadrao>
        }

        <ButtonPadrao Class="btn-secondary" OnClick="FecharModal">
            <i class="fas fa-times me-2"></i> Cancelar
        </ButtonPadrao>
        <ButtonPadrao Class="btn-primary" OnClick="Salvar">
            <i class="fas fa-save me-2"></i> Salvar
        </ButtonPadrao>
    </FooterContent>
</ModalPadrao>


@code {

    protected override async Task OnInitializedAsync()
    {
        await CarregarLista();
    }

    #region Propriedades

    private DtoFormaPagamento formaPagamento = new();
    private List<DtoFormaPagamento> listaFormasPagamento = new();
    private int paginaAtual = 1;
    private string Titulo = "Consulta de Formas de Pagamento";
    private bool exibirModal = false;
    private DtoFiltro filtroAtual = new();

    #endregion

    #region Paginacao

    private async Task CarregarLista(DtoFiltro filtro = null)
    {
        filtroAtual = filtro;
        paginaAtual = 1;

        var response = new Aplicacao.Dtos.Wrappers.ResultadoOperacao<List<DtoFormaPagamento>>();

        if (filtro?.Campos?.Count > 0)
        {
            response = await ApiServicoFormasPagamentos.ObtenhaListaComFiltros(filtro);
        }
        else
        {
            response = await ApiServicoFormasPagamentos.ObtenhaLista();
        }

        if (response.Sucesso)
        {
            listaFormasPagamento = response.Dados ?? new();
        }
    }

    private void PaginaAlterada(int novaPagina)
    {
        paginaAtual = novaPagina;
    }

    #endregion

    #region CRUD

    private void Novo()
    {
        formaPagamento = new DtoFormaPagamento();
        exibirModal = true;
    }

    private void Editar(DtoFormaPagamento item)
    {
        this.formaPagamento = new DtoFormaPagamento
        {
            Codigo = item.Codigo,
            Nome = item.Nome,
            Descricao = item.Descricao
        };
        exibirModal = true;
    }

    private async Task Salvar()
    {
        var novo = formaPagamento.Codigo == 0;

        var confirmado = await JS.InvokeAsync<bool>("MessageBoxConfirmacao",
                                    novo == true ? $"Deseja realmente cadastrar a forma de pagamento {formaPagamento.Nome}?" :
                                                   $"Deseja realmente atualizar a forma de pagamento {formaPagamento.Nome}?");

        if (confirmado)
        {
            var response = novo == true ? await ApiServicoFormasPagamentos.Cadastrar(formaPagamento) : await ApiServicoFormasPagamentos.Atualizar(formaPagamento);

            await JS.InvokeVoidAsync("MessageBoxResultado", response.Sucesso, response.Mensagem);

            if (response.Sucesso)
            {
                exibirModal = false;
                await CarregarLista();
            }

        }
    }

    private async Task Excluir()
    {
        var confirmado = await JS.InvokeAsync<bool>("MessageBoxConfirmacao",
                                                   $"Deseja realmente excluir a forma de pagamento {formaPagamento.Nome}?");

        if (confirmado)
        {
            var response = await ApiServicoFormasPagamentos.Deletar(formaPagamento.Codigo);

            await JS.InvokeVoidAsync("MessageBoxResultado", response.Sucesso, response.Mensagem);

            if (response.Sucesso)
            {
                exibirModal = false;
                await CarregarLista();
            }
        }
    }

    #endregion

    private void FecharModal()
    {
        exibirModal = false;
    }
}
