@page "/Agentes/Agente"

@using Hiper.Erp.Aplicacao.Dtos.Agentes
@using Hiper.Erp.Aplicacao.Dtos.ObjetosDeValor.Filtros
@using Hiper.Erp.Aplicacao.Interfaces.Servicos
@using Hiper.Erp.Aplicacao.Interfaces.Servicos.Agentes
@using Hiper.Erp.Apresentacao.Web.Components.Accordions
@using Hiper.Erp.Apresentacao.Web.Components.Buttons
@using Hiper.Erp.Apresentacao.Web.Components.Cards
@using Hiper.Erp.Apresentacao.Web.Components.Containers
@using Hiper.Erp.Apresentacao.Web.Components.Table
@using Hiper.Erp.Apresentacao.Web.Components.Modals
@inject IServicoAgentes ApiServicoAgentes
@inject IJSRuntime JS

<ContainerPadrao Breakpoint="xxl">
    <RowPadrao>
        <ColPadrao>
            <CardPadrao>

                <CardHeaderPadrao Class="p-3">

                    <AccordionPadrao Class="mb-0">
                        <AccordionItem Title="@Titulo" Icon="nav-icon fas fa-user"> </AccordionItem>
                    </AccordionPadrao>

                </CardHeaderPadrao>

                <CardBodyPadrao Class="p-0">

                    <TablePadrao TItem="DtoAgente"
                                 Itens="@listaAgentes"
                                 ItensPorPagina="10"
                                 OnPaginaAlterada="PaginaAlterada"
                                 OnFiltrar="CarregarLista"
                                 OnAdicionar="Novo"
                                 OnRowClick="Editar">

                        <ColunaAcoes Context="agenteItem">
                            <AgenteAcoes Agente="agenteItem"
                                         OnEditar="Editar"
                                         OnExcluir="Excluir"
                                         OnFuncoes="AbrirFuncoes" />
                        </ColunaAcoes>

                    </TablePadrao>
                </CardBodyPadrao>
            </CardPadrao>
        </ColPadrao>
    </RowPadrao>
</ContainerPadrao>

<ModalPadrao Title="@(agente.Codigo == 0 ? "Novo" : "Editar")"
             Visible="@exibirModal"
             CloseOnBackdrop="false"
             Size="xl"
             Centered="true">
    <ChildContent>
        <AgenteFormulario Agente="agente" />
    </ChildContent>
    <FooterContent>
        @if (agente.Codigo > 0)
        {
            <ButtonPadrao Class="btn-secondary" OnClick="Excluir">
                <i class="fas fa-trash me-2"></i> Excluir
            </ButtonPadrao>
        }

        <ButtonPadrao Class="btn-secondary" OnClick="FecharModal">
            <i class="fas fa-times me-2"></i> Cancelar
        </ButtonPadrao>
        <ButtonPadrao Class="btn-primary" OnClick="Salvar">
            <i class="fas fa-save me-2"></i> Salvar
        </ButtonPadrao>
    </FooterContent>
</ModalPadrao>


@code {

    protected override async Task OnInitializedAsync()
    {
        await CarregarLista();
    }

    #region Propriedades

    private DtoAgente agente = new();
    private List<DtoAgente> listaAgentes = new();
    private int paginaAtual = 1;
    private string Titulo = "Consulta de Agentes";
    private bool exibirModal = false;
    private DtoFiltro filtroAtual = new();

    #endregion

    #region Paginacao

    private async Task CarregarLista(DtoFiltro filtro = null)
    {
        filtroAtual = filtro;
        paginaAtual = 1;

        var response = new Aplicacao.Dtos.ObjetosDeValor.Wrappers.ResultadoOperacao<List<DtoAgente>>();

        if (filtro?.Campos?.Count > 0)
        {
            response = await ApiServicoAgentes.ObtenhaListaComFiltros(filtro);
        }
        else
        {
            response = await ApiServicoAgentes.ObtenhaLista();
        }

        if (response.Sucesso)
        {
            listaAgentes = response.Dados ?? new();
        }
    }

    private void PaginaAlterada(int novaPagina)
    {
        paginaAtual = novaPagina;
    }

    #endregion

    #region CRUD

    private void Novo()
    {
        agente = new DtoAgente { Ativo = true };
        exibirModal = true;
    }

    private void Editar(DtoAgente agente)
    {       
        this.agente = new DtoAgente
        {
            Codigo = agente.Codigo,
            RazaoNome = agente.RazaoNome,
            FantasiaApelido = agente.FantasiaApelido,
            CnpjCpf = agente.CnpjCpf,
            Ativo = agente.Ativo,
            AgenteCliente = agente.AgenteCliente,            
            Observacao = agente.Observacao
        };
        exibirModal = true;
    }

    private async Task Salvar()
    {
        var novo = agente.Codigo == 0;

        var confirmado = await JS.InvokeAsync<bool>("MessageBoxConfirmacao",
                                    novo == true ? $"Deseja realmente cadastrar o agente {agente.RazaoNome}?" :
                                                   $"Deseja realmente atualizar o agente {agente.RazaoNome}?");

        if (confirmado)
        {
            var response = novo == true ? await ApiServicoAgentes.Cadastrar(agente) : await ApiServicoAgentes.Atualizar(agente);

            await JS.InvokeVoidAsync("MessageBoxResultado", response.Sucesso, response.Mensagem);

            if (response.Sucesso)
            {
                exibirModal = false;
                await CarregarLista();
            }

        }
    }

    private async Task Excluir()
    {
        var confirmado = await JS.InvokeAsync<bool>("MessageBoxConfirmacao",
                                                   $"Deseja realmente excluir o agente {agente.RazaoNome}?");

        if (confirmado)
        {
            var response = await ApiServicoAgentes.Deletar(agente.Codigo);

            await JS.InvokeVoidAsync("MessageBoxResultado", response.Sucesso, response.Mensagem);

            if (response.Sucesso)
            {
                await CarregarLista();
            }
        }
    }

    #endregion


    private async Task AbrirFuncoes()
    {
        bool sucesso;

        if (agente.Codigo == 0)
            sucesso = (await ApiServicoAgentes.Cadastrar(agente)).Sucesso;
        else
            sucesso = (await ApiServicoAgentes.Atualizar(agente)).Sucesso;

        if (sucesso)
        {
            exibirModal = false;
            await CarregarLista();
        }
    }


    private void FecharModal()
    {
        exibirModal = false;
    }
}
